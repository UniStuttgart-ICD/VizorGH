    <!-- <PostBuildEvent>Copy "$(TargetPath)" "$(TargetDir)$(ProjectName).dll"
Copy "$(TargetPath)" "$(AppData)\Grasshopper\Libraries\Vizor\VizorLibs.dll"</PostBuildEvent>
  </PropertyGroup> -->

  <!-- Reference WinForms only for Windows target frameworks -->
  <ItemGroup Condition="$(TargetFramework.Contains('-windows'))">
    <!-- Rhino 8.11 and later you can use this -->
    <FrameworkReference Include="Microsoft.WindowsDesktop.App.WindowsForms" />
  </ItemGroup>

</Project>